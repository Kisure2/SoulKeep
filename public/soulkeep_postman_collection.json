{
	"info": {
		"_postman_id": "c8d8b671-1250-48b4-9214-9988ff88ccaa",
		"name": "SoulKeep Mental Health API (SDG 3)",
		"description": "Postman Collection resmi untuk pengujian SoulKeep Mental Health API. Mendukung keamanan bertingkat: API Key, JWT Bearer Token, dan Basic Auth.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Autentikasi Publik",
			"item": [
				{
					"name": "Register User Baru",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-API-KEY",
								"value": "{{api_key}}",
								"description": "API Key Lapis 1 wajib disertakan"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Mahasiswa UGM\",\n    \"email\": \"mahasiswa@ugm.ac.id\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"register"
							]
						},
						"description": "Endpoint publik untuk mendaftarkan akun mahasiswa baru."
					},
					"response": []
				},
				{
					"name": "Login User (Mendapatkan JWT)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if(jsonData.token) {",
									"    pm.globals.set(\"jwt_token\", jsonData.token);",
									"    console.log(\"JWT Token otomatis disimpan ke global variable 'jwt_token'!\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-API-KEY",
								"value": "{{api_key}}",
								"description": "API Key Lapis 1 wajib"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"mahasiswa@ugm.ac.id\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"login"
							]
						},
						"description": "Endpoint login. Respons sukses akan mengembalikan JWT Bearer Token yang otomatis disimpan ke variabel Postman `{{jwt_token}}`."
					},
					"response": []
				}
			]
		},
		{
			"name": "2. Pelacakan Mood (JWT Auth)",
			"item": [
				{
					"name": "Ambil Riwayat Mood Pribadi",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [
							{
								"key": "X-API-KEY",
								"value": "{{api_key}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/moods",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"moods"
							]
						},
						"description": "Membaca seluruh riwayat mood khusus milik pengguna yang sedang login via JWT."
					},
					"response": []
				},
				{
					"name": "Simpan Mood Baru",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-API-KEY",
								"value": "{{api_key}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"score\": 8,\n    \"notes\": \"Hari yang luar biasa karena berhasil menyelesaikan tugas kelompok Laravel!\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/moods",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"moods"
							]
						},
						"description": "Mencatat mood baru (skala 1-10) beserta catatan curhatan singkat."
					},
					"response": []
				}
			]
		},
		{
			"name": "3. Administrator (Basic Auth)",
			"item": [
				{
					"name": "Ambil Seluruh Pengguna (Basic Auth)",
					"request": {
						"auth": {
							"type": "basic",
							"basic": [
								{
									"key": "password",
									"value": "password123",
									"type": "string"
								},
								{
									"key": "username",
									"value": "mahasiswa@ugm.ac.id",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [
							{
								"key": "X-API-KEY",
								"value": "{{api_key}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/admin/users",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"admin",
								"users"
							]
						},
						"description": "Mengakses daftar seluruh pengguna terdaftar menggunakan Basic Authentication (masukkan email dan password akun terdaftar)."
					},
					"response": []
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "api_key",
			"value": "rahasia-uas-123",
			"type": "string"
		}
	]
}
